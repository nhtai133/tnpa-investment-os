# TNPA Investment OS — Environment Variables
# Copy this file to .env.local for local development.
# .env.local is gitignored and never committed.

# ---------------------------------------------------------------------------
# Database — connection resolution order:
#   1. TURSO_DATABASE_URL  (if set, Turso Cloud is used)
#   2. DATABASE_URL        (custom libSQL or local SQLite)
#   3. file:tnpa-investment.db  (automatic fallback — no config needed locally)
# ---------------------------------------------------------------------------

# Local SQLite (default for local dev — leave TURSO_DATABASE_URL blank)
DATABASE_URL=file:tnpa-investment.db

# Turso Cloud (production) — leave blank to use local SQLite
# Get these from: turso db show <db-name> && turso db tokens create <db-name>
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# App Environment
# ---------------------------------------------------------------------------
# Values: local | development | staging | production
APP_ENV=local

# ---------------------------------------------------------------------------
# App Name (exposed to the browser)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=TNPA Investment OS
