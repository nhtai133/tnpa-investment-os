# TNPA Investment OS — Environment Variables
# Copy this file to .env.local for local development.
# .env.local is gitignored and never committed.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# For local development, use a local SQLite file (default — no change needed):
#   DATABASE_URL=file:tnpa-investment.db
#
# For production on Vercel, use a remote LibSQL/Turso connection string:
#   DATABASE_URL=libsql://your-db.turso.io?authToken=YOUR_TOKEN
#
DATABASE_URL=file:tnpa-investment.db

# ---------------------------------------------------------------------------
# App Environment
# ---------------------------------------------------------------------------
# Values: development | production | staging
APP_ENV=development

# ---------------------------------------------------------------------------
# App Name (exposed to the browser)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=TNPA Investment OS
